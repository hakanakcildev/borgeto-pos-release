{
  "name": "borgeto-pos-electron",
  "version": "1.0.32",
  "description": "Borgeto POS - Electron Desktop Application",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.cjs",
    "build:electron": "npm run build && electron-builder",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build:electron",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:win": "cross-env ELECTRON_FORGE_PLATFORM=win32 electron-forge make",
    "make:mac": "cross-env ELECTRON_FORGE_PLATFORM=darwin electron-forge make",
    "make:linux": "cross-env ELECTRON_FORGE_PLATFORM=linux electron-forge make",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "keywords": [
    "electron",
    "pos",
    "point-of-sale"
  ],
  "author": "Borgeto",
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-router": "^1.139.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.1.0",
    "lucide-react": "^0.554.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tanstack/router-plugin": "^1.139.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-squirrel-startup": "^1.0.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^8.0.1",
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/maker-deb": "^7.6.0",
    "@electron-forge/maker-rpm": "^7.6.0",
    "@electron-forge/plugin-fuses": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@electron/fuses": "^1.8.0"
  },
  "build": {
    "appId": "com.borgeto.pos",
    "productName": "Borgeto POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "public/**/*",
      "node_modules/**/*",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}",
      "!**/node_modules/.cache/**/*",
      "!**/node_modules/**/*.{md,ts,map}",
      "!**/node_modules/**/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/**/.{bin,o,hprof,orig,pyc,pyo,rbc}",
      "!**/node_modules/**/{.nyc_output,coverage,.nyc_output,*.tsbuildinfo}"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/@electron/**/*",
      "**/node_modules/electron-updater/**/*",
      "**/node_modules/electron-updater/out/**/*"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js",
      "type": "commonjs"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "publisherName": "Borgeto",
      "icon": "public/borgeto-logo.ico",
      "artifactName": "${productName} ${version}.${ext}",
      "requestedExecutionLevel": "asInvoker",
      "verifyUpdateCodeSignature": false
    },
    "icon": "public/images/borgeto-logo.png",
    "publish": [
      {
        "provider": "github",
        "owner": "hakanakcildev",
        "repo": "borgeto-pos-release",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "artifactName": "${productName} Setup ${version}.${ext}",
      "shortcutName": "${productName}",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "public/borgeto-logo.ico",
      "uninstallerIcon": "public/borgeto-logo.ico",
      "installerHeaderIcon": "public/borgeto-logo.ico",
      "warningsAsErrors": false,
      "perMachine": false,
      "differentialPackage": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
