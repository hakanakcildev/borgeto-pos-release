{
  "name": "borgeto-pos-electron",
  "version": "2.0.55",
  "description": "Borgeto POS - Electron Desktop Application",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.cjs",
    "build:win": "node scripts/build.cjs --win",
    "build:mac": "node scripts/build.cjs --mac",
    "build:linux": "node scripts/build.cjs --linux",
    "build:patch": "node scripts/build.cjs --patch",
    "build:minor": "node scripts/build.cjs --minor",
    "build:major": "node scripts/build.cjs --major",
    "build:win:patch": "node scripts/build.cjs --win --patch",
    "build:win:minor": "node scripts/build.cjs --win --minor",
    "build:win:major": "node scripts/build.cjs --win --major",
    "build:electron": "npm run build && electron-builder",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build:electron",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:win": "cross-env ELECTRON_FORGE_PLATFORM=win32 electron-forge make",
    "make:mac": "cross-env ELECTRON_FORGE_PLATFORM=darwin electron-forge make",
    "make:linux": "cross-env ELECTRON_FORGE_PLATFORM=linux electron-forge make",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "keywords": [
    "electron",
    "pos",
    "point-of-sale"
  ],
  "author": "Borgeto",
  "license": "MIT",
  "overrides": {
    "tmp": "^0.2.5"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-router": "^1.141.2",
    "@types/node-cron": "^3.0.11",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.1.7",
    "firebase": "^12.1.0",
    "lucide-react": "^0.554.0",
    "node-cron": "^4.2.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.6.0",
    "@electron-forge/maker-rpm": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-fuses": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.39.1",
    "@tanstack/router-plugin": "^1.141.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "electron": "^39.2.7",
    "electron-builder": "^25.1.8",
    "electron-squirrel-startup": "^1.0.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.borgeto.pos",
    "productName": "Borgeto POS",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/@electron/**/*",
      "**/node_modules/electron-updater/**/*",
      "**/node_modules/electron-updater/out/**/*"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js",
      "type": "commonjs"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/images/borgeto-logo-512.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "Borgeto",
      "icon": "public/borgeto-logo.ico",
      "artifactName": "${productName}.${ext}",
      "requestedExecutionLevel": "asInvoker",
      "verifyUpdateCodeSignature": false
    },
    "icon": "public/images/borgeto-logo.png",
    "publish": [
      {
        "provider": "github",
        "owner": "hakanakcildev",
        "repo": "borgeto-pos-release",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "artifactName": "BorgetoPOSSetup.${ext}",
      "shortcutName": "${productName}",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": true,
      "installerIcon": "public/borgeto-logo.ico",
      "uninstallerIcon": "public/borgeto-logo.ico",
      "installerHeaderIcon": "public/borgeto-logo.ico",
      "warningsAsErrors": false,
      "perMachine": false,
      "differentialPackage": false,
      "packElevateHelper": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
